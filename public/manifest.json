{
  "manifest_version": 3,
  "name": "9Router Quota Checker",
  "version": "0.1.1",
  "description": "Monitor quota for provider accounts connected to your local 9Router instance.",
  "action": {
    "default_title": "9Router Quota Checker",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ]
}
