{
  "name": "opencode-9router-quota",
  "version": "0.1.0",
  "description": "OpenCode TUI plugin that displays quota from a local 9Router instance.",
  "type": "module",
  "license": "MIT",
  "exports": {
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.jsx"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22",
    "opencode": ">=1.3.13"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.3.13"
  },
  "dependencies": {
    "@opentui/core": "0.4.5",
    "@opentui/solid": "0.4.5",
    "solid-js": "1.9.10"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.18.4",
    "@types/node": "24.12.2",
    "typescript": "5.8.2",
    "vitest": "4.1.10"
  },
  "packageManager": "bun@1.3.14"
}
